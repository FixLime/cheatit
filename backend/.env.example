PORT=3000
API_KEY=change_me

# --- Server provider (choose one) ---
# Option A: Dathost (recommended, has free tier)
DATHOST_USER=your@email.com
DATHOST_PASSWORD=yourpassword
DATHOST_GAME_SERVER_ID=your_server_id   # clone this server per match

# Option B: Self-hosted Docker
DOCKER_HOST=unix:///var/run/docker.sock
CS2_IMAGE=joedwards32/cs2
CS2_GSLT=your_gslt_token
SERVER_IP=1.2.3.4                       # your VPS public IP
SERVER_PORT_START=27015                 # ports allocated from here

# Database
DB_PATH=./cheatit.db
